---
interface Props {
  headline: string;
  description: string;
  image?: string;
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  siteUrl?: string;
}
const { headline, description, image, author = "v0-Guide Team", publishedTime, modifiedTime, siteUrl } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": headline,
  "description": description,
  "image": image ? new URL(image, siteUrl).href : undefined,
  "author": { "@type": "Person", "name": author },
  "publisher": { "@type": "Organization", "name": "v0-Guide", "logo": { "@type": "ImageObject", "url": new URL("/assets/logo.png", siteUrl).href } },
  "datePublished": publishedTime ? new Date(publishedTime).toISOString() : new Date().toISOString(),
  "dateModified": modifiedTime ? new Date(modifiedTime).toISOString() : new Date().toISOString(),
  "mainEntityOfPage": { "@type": "WebPage", "@id": Astro.url?.href || siteUrl }
};
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />