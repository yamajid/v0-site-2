---
import ArticleLayout from '@layouts/ArticleLayout.astro';
const title = 'Getting Started with v0: A Complete Beginner\'s Guide';
const description = 'Learn how to use v0 by Vercel to generate production-ready UI components using AI.';
---
<ArticleLayout title={title} description={description}>
  <article class="prose prose-slate max-w-none">
    <h1>{title}</h1>
    <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-amber-800 font-medium">🚧 Content coming soon</p>
      <p class="text-amber-700 text-sm mt-1">This article is being prepared. Check back soon for the full guide.</p>
    </div>
  </article>
</ArticleLayout>