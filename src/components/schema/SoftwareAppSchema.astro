---
interface Props {
  name: string;
  category?: string;
  operatingSystem?: string[];
  offers?: Array<{ price: string | number; currency: string; availability?: string }>;
}
const { name, category = "DeveloperApplication", operatingSystem = ["Web"], offers } = Astro.props;

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": name,
  "applicationCategory": category,
  "operatingSystem": operatingSystem,
  "offers": offers?.map(o => ({
    "@type": "Offer",
    "price": String(o.price),
    "priceCurrency": o.currency,
    "availability": o.availability || "https://schema.org/InStock"
  }))
};
---
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />