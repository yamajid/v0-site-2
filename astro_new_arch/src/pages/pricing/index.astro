---
// src/pages/pricing.astro
// Fixed: All 5 tiers, correct pricing, affiliate CTAs

import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Pricing - v0-guide';
const description = 'Compare v0 pricing tiers: Free, Premium, Team, Business, and Enterprise. Find the right plan for your AI development workflow.';

// ✅ Corrected Pricing Data per SEO Report (Section 6.1)
const tiers = [
  {
    name: 'Free',
    price: '$0',
    frequency: '/mo',
    description: 'Perfect for hobbyists and learning the basics of AI-generated UI.',
    features: [
      '100 generations per month',
      'Community support',
      'Standard export options',
      'Access to basic components'
    ],
    cta: 'Start for Free',
    url: 'https://v0.dev?ref=v0-guide',
    popular: false
  },
  {
    name: 'Premium',
    price: '$20',
    frequency: '/mo',
    description: 'Ideal for freelancers and indie developers building real projects.',
    features: [
      'Unlimited generations',
      'Priority processing queue',
      'Custom domain export',
      'Private projects',
      'Advanced model access'
    ],
    cta: 'Get Premium',
    url: 'https://v0.dev?ref=v0-guide',
    popular: true
  },
  {
    name: 'Team',
    price: '$30',
    frequency: '/user/mo',
    description: 'Collaborate seamlessly with small agencies and dev teams.',
    features: [
      'Everything in Premium',
      'Shared team workspace',
      'Version history',
      'Collaborative editing',
      'Admin dashboard'
    ],
    cta: 'Start Team Trial',
    url: 'https://v0.dev?ref=v0-guide',
    popular: false
  },
  {
    name: 'Business',
    price: '$100',
    frequency: '/user/mo',
    description: 'Enterprise-grade features for scaling organizations.',
    features: [
      'Everything in Team',
      'SSO (Single Sign-On)',
      'Audit logs',
      'Dedicated support',
      'SLA guarantees'
    ],
    cta: 'Contact Sales',
    url: 'https://v0.dev?ref=v0-guide',
    popular: false
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    frequency: '',
    description: 'Tailored solutions for large organizations with specific needs.',
    features: [
      'Everything in Business',
      'On-premise deployment',
      'Custom model fine-tuning',
      'White-label options',
      'Dedicated account manager'
    ],
    cta: 'Contact Sales',
    url: 'https://v0.dev?ref=v0-guide',
    popular: false
  }
];
---

<BaseLayout title={title} description={description}>
  
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Simple, Transparent Pricing
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
    </div>
  </section>

  <!-- Pricing Grid -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Note: For Enterprise/Custom, we might stack differently, but grid works for all 5 -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        
        {tiers.map((tier) => (
          <div class={`relative flex flex-col rounded-2xl border p-6 shadow-sm transition-all hover:shadow-md ${tier.popular ? 'border-primary-500 ring-2 ring-primary-500 ring-offset-2' : 'border-slate-200'}`}>
            
            <!-- Popular Badge -->
            {tier.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
                Most Popular
              </span>
            )}

            <!-- Header -->
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-slate-900">{tier.name}</h3>
              <p class="mt-1 text-sm text-slate-500">{tier.description}</p>
            </div>

            <!-- Price -->
            <div class="mb-6">
              <span class="text-4xl font-bold text-slate-900">{tier.price}</span>
              <span class="text-slate-500">{tier.frequency}</span>
            </div>

            <!-- Features -->
            <ul class="mb-8 flex-1 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg class="h-5 w-5 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a 
              href={tier.url}
              class={`block w-full rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${
                tier.popular 
                  ? 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm' 
                  : 'bg-slate-900 text-white hover:bg-slate-800'
              }`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {tier.cta}
            </a>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- FAQ Section (SEO Boost) -->
  <section class="bg-slate-50 py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-slate-900 mb-10">Frequently Asked Questions</h2>
      
      <div class="space-y-8">
        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>What happens if I exceed my generation limit?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            Once you reach your monthly limit on the Free plan, you won't be able to generate new components until the next month, or you can upgrade to Premium for unlimited access.
          </p>
        </details>

        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>Can I export the code to my own project?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            Yes! v0 generates standard React + Tailwind CSS code that you can copy and paste directly into your existing projects. Premium and Team plans also offer direct export to GitHub and custom domains.
          </p>
        </details>

        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>Is there a discount for annual billing?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            Pricing shown is monthly. Check the official v0 pricing page for any current annual discounts or team volume pricing.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to build faster?</h2>
      <p class="mt-4 text-lg text-slate-300">
        Join thousands of developers using v0 to accelerate their UI workflow.
      </p>
      <div class="mt-8">
        <a 
          href="https://v0.dev?ref=v0-guide"
          class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3 text-base font-bold text-white shadow-lg transition-transform hover:scale-105 hover:bg-primary-700"
        >
          Start Building for Free
        </a>
      </div>
    </div>
  </section>

</BaseLayout>