---
import BaseLayout from '../layouts/BaseLayout.astro';
import SoftwareAppSchema from '../components/schema/SoftwareAppSchema.astro';
import FAQSection from '../components/schema/FAQSection.astro';
import FreshnessStamp from '../components/FreshnessStamp.astro';
import { definePageMeta } from '@lib/metadata';


const meta = definePageMeta({
  title: 'What is v0 by Vercel?',
  description: 'Learn what v0 by Vercel is, how it works, and why developers love this AI-powered UI generation tool.',
  path: '/what-is-v0-by-vercel',
  image: '/assets/og-what-is-v0.jpg',
  keywords: ['guide', 'introduction', 'how-it-works'],
});

const faqItems = [
  { question: "What is v0 by Vercel?", answer: "v0 is an AI-powered UI generation tool that translates natural language prompts into production-ready React and Tailwind CSS code, accelerating frontend development workflows." },
  { question: "Is v0 free?", answer: "Yes. v0 offers a free tier with 100 generations/month, ideal for prototyping and personal projects." },
  { question: "Does v0 integrate with GitHub?", answer: "Yes. v0 supports native GitHub sync for pushing, pulling, branching, and creating PRs directly from the interface." }
];
---
<BaseLayout meta={meta}>
  <SoftwareAppSchema name="v0 by Vercel" offers={[{ price: "0", currency: "USD" }, { price: "20", currency: "USD" }]} />
  
  <article class="prose lg:prose-xl mx-auto py-12 px-4 max-w-4xl">
    <h1>What is v0 by Vercel?</h1>
    <p class="lead">v0 is an AI-powered UI generation tool that translates natural language prompts into production-ready React and Tailwind CSS code. It bridges the gap between design intent and functional implementation, saving developers an average of ~20 hours per week on boilerplate tasks.</p>
    
    <h2>Core Value & Real-World Impact</h2>
    <p>Developers describe v0 as <em>"basically cheating if you're already in the Next.js ecosystem"</em> and a <em>"game changer for rapid prototyping."</em> It integrates seamlessly with GitHub, Supabase, and Vercel deployments, enabling agentic workflows from concept to production.</p>
    
    <FreshnessStamp modified={new Date()} />
    <FAQSection items={faqItems} />
  </article>
</BaseLayout>