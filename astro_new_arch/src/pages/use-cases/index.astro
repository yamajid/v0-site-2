---
// src/pages/use-cases/index.astro
// Minimal static page: Use Cases Hub (placeholder)

import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Use Cases - v0-guide';
const description = 'Explore real-world ways to use v0 by Vercel for faster UI development.';

// ✅ Planned use cases per SEO strategy (Section 2.3)
const useCases = [
  {
    slug: 'internal-tools-dashboards',
    title: 'Building Internal Tools & Admin Dashboards',
    description: 'Rapidly generate admin panels, data tables, and workflow tools.',
    icon: '📊'
  },
  {
    slug: 'prototyping-wireframing',
    title: 'Product Prototyping & Wireframing',
    description: 'Go from idea to interactive prototype in minutes, not hours.',
    icon: '✏️'
  },
  {
    slug: 'personal-projects-side-hustles',
    title: 'Personal Projects & Side-Hustles',
    description: 'Build landing pages, portfolios, and MVPs without design skills.',
    icon: '🚀'
  },
  {
    slug: 'agentic-workflows',
    title: 'Agentic Development Workflows',
    description: 'Integrate v0 into AI agent pipelines for autonomous UI generation.',
    icon: '🤖'
  },
];
---

<BaseLayout title={title} description={description}>
  
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700">
        Use Cases
      </span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        How Teams Use v0
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
    </div>
  </section>

  <!-- Use Cases Grid -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2">
        {useCases.map((useCase) => (
          <a 
            href={`/use-cases/${useCase.slug}`}
            class="group block p-6 rounded-xl border border-slate-200 bg-white shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
          >
            <div class="text-3xl mb-4">{useCase.icon}</div>
            <h3 class="text-lg font-semibold text-slate-900 group-hover:text-primary-600">
              {useCase.title}
            </h3>
            <p class="mt-2 text-sm text-slate-600">
              {useCase.description}
            </p>
            <p class="mt-4 text-sm text-primary-600 font-medium group-hover:underline">
              Learn more →
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 py-12">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white">Ready to accelerate your workflow?</h2>
      <p class="mt-2 text-slate-300">Start generating production-ready UIs with v0 today.</p>
      <div class="mt-6">
        <a 
          href="https://v0.dev?ref=v0-guide"
          class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-bold text-white hover:bg-primary-700 transition"
        >
          Try v0 Free →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
