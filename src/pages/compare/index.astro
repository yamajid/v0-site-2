---
// src/pages/compare/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorByline from '@/components/Astro/AuthorByline.astro';
import { definePageMeta } from '@/lib/metadata';
import { getCollection } from 'astro:content';
import { getPageMeta } from '@/data/page-metadata.ts';

const pageMeta = getPageMeta('/compare');
  
const title = 'Compare AI UI Builders - v0-guide';
const description = 'How does v0 by Vercel stack up against other AI UI generators and coding assistants?';

const meta = definePageMeta({
  title: 'Compare AI UI Builders - v0-guide',
  description: 'How does v0 by Vercel stack up against other AI UI generators and coding assistants?',
  path: '/compare',
  image: '/assets/og-home.jpg',
  keywords: ['compare', 'ai-ui', 'v0 alternatives'],
  publishedTime: pageMeta.datePublished,
  modifiedTime: pageMeta.dateModified,
});

const sortedComparisons = (await getCollection('compare')).sort(
(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

---

<BaseLayout meta={meta}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700">
        Compare Tools
      </span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        v0 vs The Ecosystem
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
    </div>
  </section>

  <!-- Comparison Map -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {sortedComparisons.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-gray-500 text-lg">Comparisons coming soon. Stay tuned!</p>
        </div>
      ) : (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {sortedComparisons.map((item) => (
            <a 
              href={`/compare/${item.slug}`}
              class="group block p-6 rounded-xl border border-slate-200 bg-white shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="text-2xl font-bold text-slate-900">v0</div>
                <div class="text-sm font-medium text-slate-400 border border-slate-200 rounded px-2 py-1">vs</div>
                <div class="text-2xl font-bold text-slate-900">{item.data.title.replace('v0 vs ', '').replace('v0 vs. ', '')}</div>
              </div>
              <h3 class="text-lg font-semibold text-slate-900 group-hover:text-primary-600">
                {item.data.title}
              </h3>
              <p class="mt-2 text-sm text-slate-600 mb-4 h-10 line-clamp-2">
                {item.data.description}
              </p>
              <div class="flex items-center text-sm text-primary-600 font-medium pb-2">
                <span>Read analysis</span>
                <svg class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 py-12">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white">Compare for yourself</h2>
      <p class="mt-2 text-slate-300">Experience how fast you can iterate with v0.</p>
      <div class="mt-6">
        <a 
          href="https://v0.app?ref=v0-guide"
          target="_blank"
          rel="noopener noreferrer sponsored"
          class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-bold text-white hover:bg-primary-700 transition"
        >
          Try v0 Free →
        </a>
      </div>
    </div>
  </section>
  <article class="mx-auto max-w-4xl px-4 py-12">
    <AuthorByline author="v0 Guide" date={new Date(2026, 3, 20)} linkedIn="https://linkedin.com/in/yamajid" github="https://github.com/yamajid" />
  </article>
</BaseLayout>
