---
interface Props {
  links: Array<{ title: string; url: string; type: string }>;
}
const { links } = Astro.props;
---
<aside class="mt-12 p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
  <h3 class="text-xl font-bold mb-4">Explore Related Guides & Comparisons</h3>
  <ul class="space-y-3">
    {links.map(link => (
      <li>
        <a href={link.url} class="block p-4 bg-white dark:bg-gray-800 rounded-lg hover:shadow-md transition border border-gray-100 dark:border-gray-700">
          <span class="text-xs font-semibold text-blue-600 uppercase tracking-wide">{link.type}</span>
          <span class="block font-medium text-gray-900 dark:text-gray-100 mt-1">{link.title}</span>
        </a>
      </li>
    ))}
  </ul>
</aside>