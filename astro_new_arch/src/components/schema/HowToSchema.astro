---
interface Props {
  name: string;
  steps: Array<{ name: string; text: string }>;
  estimatedTime?: string; // ISO 8601 duration, e.g., "PT15M"
}
const { name, steps, estimatedTime } = Astro.props;

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": name,
  "step": steps.map((step, i) => ({
    "@type": "HowToStep",
    "position": i + 1,
    "name": step.name,
    "text": step.text
  })),
  ...(estimatedTime ? { "totalTime": estimatedTime } : {})
};
---
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />