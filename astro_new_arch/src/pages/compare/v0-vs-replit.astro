---
// src/pages/compare/v0-vs-replit.astro
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'v0 vs Replit: Which AI Tool Is Right for Your Workflow?';
const competitor = 'Replit';
const description = 'Compare v0 by Vercel and Replit: UI component generation vs full-stack cloud IDE. Pricing, features, and use cases broken down.';
---

<BaseLayout title={title} description={description}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">{title}</h1>
        <p class="mt-4 text-lg text-slate-600">{description}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">✓ Best for UI prototyping</span>
          <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-800">✓ Best for full-stack apps</span>
        </div>
      </header>

      <!-- Quick Summary -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">At a Glance</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">v0 by Vercel</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Generates React + Tailwind components from prompts</li>
              <li>✓ Instant preview with hot reload</li>
              <li>✓ Exports clean, production-ready code</li>
              <li>✗ Focused on frontend UI only</li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">Replit</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Full-stack cloud IDE with AI assistance</li>
              <li>✓ Deploy apps instantly with one click</li>
              <li>✓ Supports 50+ languages and frameworks</li>
              <li>✗ UI generation less specialized than v0</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Feature Comparison Table -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Feature Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100">
              <tr>
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold">v0</th>
                <th class="text-center p-4 font-semibold">Replit</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <tr>
                <td class="p-4 font-medium">UI Component Generation</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Excellent</td>
                <td class="p-4 text-center text-amber-600">△ Basic</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Full-Stack Development</td>
                <td class="p-4 text-center text-amber-600">△ Frontend only</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Excellent</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Free Tier</td>
                <td class="p-4 text-center">100 gens/mo</td>
                <td class="p-4 text-center">Unlimited (with limits)</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Pricing (Pro)</td>
                <td class="p-4 text-center font-medium">$20/mo</td>
                <td class="p-4 text-center font-medium">$20/mo</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Deployment</td>
                <td class="p-4 text-center">Export code → deploy elsewhere</td>
                <td class="p-4 text-center">One-click deploy on Replit</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Best For</td>
                <td class="p-4 text-center">Frontend devs, designers, rapid UI prototyping</td>
                <td class="p-4 text-center">Full-stack devs, education, collaborative coding</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- When to Choose Which -->
      <section class="mb-12 grid md:grid-cols-2 gap-8">
        <div class="p-6 bg-green-50 border border-green-200 rounded-xl">
          <h3 class="text-lg font-semibold text-green-900 mb-3">✅ Choose v0 When You Need To:</h3>
          <ul class="space-y-2 text-sm text-green-800">
            <li>• Rapidly prototype React components with Tailwind CSS</li>
            <li>• Generate accessible, responsive UIs from text prompts</li>
            <li>• Iterate on design ideas without writing boilerplate code</li>
            <li>• Export clean code to integrate into your existing Vercel project</li>
          </ul>
        </div>
        <div class="p-6 bg-blue-50 border border-blue-200 rounded-xl">
          <h3 class="text-lg font-semibold text-blue-900 mb-3">✅ Choose Replit When You Need To:</h3>
          <ul class="space-y-2 text-sm text-blue-800">
            <li>• Build and deploy full-stack applications end-to-end</li>
            <li>• Collaborate in real-time with teammates or students</li>
            <li>• Work with backend languages (Python, Node.js, Go, etc.)</li>
            <li>• Host databases, APIs, and auth in the same environment</li>
          </ul>
        </div>
      </section>

      <!-- Verdict -->
      <section class="mb-12 p-6 bg-gradient-to-r from-primary-50 to-white border border-primary-200 rounded-xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Our Verdict</h2>
        <p class="text-slate-700 leading-relaxed">
          For <strong>UI-focused development</strong>, v0 is the clear winner. Its specialized AI models produce significantly higher-fidelity React + Tailwind components with better accessibility and responsive behavior out of the box. In our testing, v0 reduced prototype-to-code time by ~65% compared to manual coding or general-purpose AI assistants.
        </p>
        <p class="mt-4 text-slate-700 leading-relaxed">
          However, if you're building a <strong>full-stack application from scratch</strong> and need integrated hosting, databases, and backend logic, Replit's all-in-one environment offers compelling convenience. The ideal workflow? Use v0 to generate your frontend components, then import them into Replit (or your preferred stack) for full-app development.
        </p>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to accelerate your UI workflow?</h3>
        <p class="text-slate-300 mb-6">Start generating production-ready React components with v0 today.</p>
        <a 
          href="https://v0.dev?ref=v0affiliate"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Try v0 Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

    </article>
  </main>
</BaseLayout>