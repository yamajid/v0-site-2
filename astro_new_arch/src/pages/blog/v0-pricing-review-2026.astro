---
import ArticleLayout from '@layouts/ArticleLayout.astro';
const title = 'v0 Pricing Tiers Explained: Which Plan Is Right for You?';
const description = 'A detailed breakdown of v0\'s pricing tiers.';
---
<ArticleLayout title={title} description={description}>
  <article class="prose prose-slate max-w-none">
    <h1>{title}</h1>
    <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-amber-800 font-medium">🚧 Content coming soon</p>
    </div>
  </article>
</ArticleLayout>