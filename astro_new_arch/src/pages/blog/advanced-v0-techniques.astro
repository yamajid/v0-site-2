---
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { definePageMeta } from '@lib/metadata.ts';

const meta = definePageMeta({
  title: 'Advanced v0 Techniques: Prompts, Iteration & Export',
  description: 'Level up your v0 workflow with advanced prompting strategies.',
  path: '/',
  image: '/assets/advanced-techniques.jpg',
  keywords: ['home', 'affiliate', 'ai-ui'],
});


// const title = 'Advanced v0 Techniques: Prompts, Iteration & Export';
const description = 'Level up your v0 workflow with advanced prompting strategies.';
---
<ArticleLayout meta={meta}>
  <article class="prose prose-slate max-w-none">
    <h1>{meta.title}</h1>
    <div class="mt-6 p-4 bg-amber-50 border border-amber-200 rounded-lg">
      <p class="text-amber-800 font-medium">🚧 Content coming soon</p>
    </div>
  </article>
</ArticleLayout>