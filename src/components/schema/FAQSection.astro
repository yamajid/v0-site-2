---
interface Props {
  items: Array<{ question: string; answer: string }>;
}
const { items } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---
<section class="space-y-3 my-12">
  {items.map(item => (
    <details class="group border border-primary-200 rounded-xl p-6 bg-gradient-to-br from-primary-50 to-white shadow-sm hover:shadow-md transition-shadow">
      <summary class="font-semibold text-lg cursor-pointer list-none flex justify-between items-center select-none text-gray-900 hover:text-primary-600">
        {item.question}
        <span class="transition-transform duration-200 group-open:rotate-180 text-primary-600">▾</span>
      </summary>
      <div class="mt-4 text-gray-700 leading-relaxed">{item.answer}</div>
    </details>
  ))}
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />