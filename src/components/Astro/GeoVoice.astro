---
import { geoPhraseBank, type PhraseCategory } from '@/data/geo-phrase-bank';

interface Props {
  title?: string;
  category?: PhraseCategory | 'mixed';
  limit?: number;
}

const {
  title = 'What users are saying',
  category = 'mixed',
  limit = 3,
} = Astro.props as Props;

const phrases = category === 'mixed'
  ? [...geoPhraseBank.positive.slice(0, 2), ...geoPhraseBank.frustration.slice(0, 2)]
  : geoPhraseBank[category];

const displayPhrases = phrases.slice(0, Math.max(1, limit));
---

<section aria-label="User sentiment" class="rounded-xl border border-gray-200 bg-gray-50 p-6">
  <h2 class="text-xl font-semibold text-gray-900">{title}</h2>
  <ul class="mt-4 space-y-3 text-sm text-gray-700">
    {displayPhrases.map((phrase) => (
      <li class="rounded-lg border border-gray-200 bg-white p-3">
        “{phrase}”
      </li>
    ))}
  </ul>
</section>
