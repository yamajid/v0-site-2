---
// src/layouts/ArticleLayout.astro
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/schema/ArticleSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import FAQSection from '../components/schema/FAQSection.astro';
import HowToSchema from '../components/schema/HowToSchema.astro';
import SoftwareAppSchema from '../components/schema/SoftwareAppSchema.astro';
import type { PageMetaResolved } from '@lib/metadata';

interface Props {
  // ✅ Unified SEO metadata (from definePageMeta)
  meta: PageMetaResolved;
  
  // ✅ Display title for <h1> (optional: defaults to base title from meta.title)
  displayTitle?: string;
  
  // ✅ Article-specific props (unchanged)
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  category?: string;
  readingTime?: number;
  
  // ✅ P2 Schema Props (optional)
  faqItems?: Array<{ question: string; answer: string }>;
  steps?: Array<{ title: string; text: string }>;
  estimatedTime?: string; // ISO 8601, e.g., "PT15M"
  softwareName?: string;
  softwareOffers?: Array<{ price: string | number; currency: string; availability?: string }>;
}

const {
  meta,
  displayTitle,
  publishedTime,
  modifiedTime,
  author = 'v0-Guide Team',
  category,
  readingTime,
  faqItems,
  steps,
  estimatedTime,
  softwareName,
  softwareOffers,
} = Astro.props;

// ✅ Extract display title: use provided value, or strip site suffix from SEO title
const h1Title = displayTitle || meta.title.split(' | ')[0];

// ✅ Generate breadcrumbs from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = pathSegments.map((segment, index) => ({
  name: segment
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' '),
  url: `https://${Astro.site?.host || 'localhost'}${pathSegments.slice(0, index + 1).join('/')}`,
  position: index + 1
}));

// ✅ Extract tags from meta.keywords (filter out global site keywords if needed)
// Optional: customize this logic based on your keyword strategy
const articleTags = meta.keywords || [];
---

<BaseLayout meta={meta}>
  <!-- Core Schemas (always injected for article pages) -->
  <ArticleSchema
    headline={h1Title}
    description={meta.description}
    image={meta.image}
    author={author}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    siteUrl={Astro.site?.href}
  />
  <BreadcrumbSchema items={breadcrumbItems} />

  <!-- Conditional Schemas (only render when props provided) -->
  {softwareName && (
    <SoftwareAppSchema name={softwareName} offers={softwareOffers} />
  )}
  {steps && steps.length > 0 && (
    <HowToSchema title={h1Title} steps={steps} estimatedTime={estimatedTime} />
  )}

  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Article Header -->
    <header class="mb-8">
      {category && (
        <span class="inline-block rounded-full bg-primary-100 px-3 py-1 text-xs font-medium text-primary-700">
          {category}
        </span>
      )}
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        {h1Title}
      </h1>
      <p class="mt-4 text-lg text-gray-600">{meta.description}</p>

      <!-- Meta Info -->
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-full bg-primary-100">
            <span class="flex h-full w-full items-center justify-center text-xs font-medium text-primary-700">
              {author.charAt(0)}
            </span>
          </div>
          <span>{author}</span>
        </div>
        {publishedTime && (
          <time datetime={publishedTime}>
            {new Date(publishedTime).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </time>
        )}
        {readingTime && <span>{readingTime} min read</span>}
      </div>
    </header>

    <!-- Featured Image -->
    {meta.image && (
      <div class="mb-8">
        <img
          src={meta.image}
          alt={h1Title}
          class="w-full rounded-xl object-cover"
          loading="lazy"
        />
      </div>
    )}

    <!-- Article Content -->
    <div class="prose prose-lg prose-gray max-w-none">
      <slot />
    </div>

    <!-- FAQ Section (renders visible HTML + schema via component) -->
    {faqItems && faqItems.length > 0 && (
      <FAQSection items={faqItems} />
    )}

    <!-- Tags -->
    {articleTags.length > 0 && (
      <div class="mt-12 border-t border-gray-200 pt-8">
        <h3 class="text-sm font-semibold text-gray-900">Tags</h3>
        <div class="mt-3 flex flex-wrap gap-2">
          {articleTags.map((tag) => (
            <a
              href={`/blog?tag=${encodeURIComponent(tag)}`}
              class="inline-block rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-200"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Article Footer -->
    <footer class="mt-12 border-t border-gray-200 pt-8">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm text-gray-500">
            Last updated: {modifiedTime 
              ? new Date(modifiedTime).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) 
              : 'N/A'}
          </p>
        </div>
        <div class="flex items-center gap-4">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(h1Title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-primary-600 transition-colors"
            aria-label="Share on Twitter"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
            </svg>
          </a>
        </div>
      </div>
    </footer>
  </article>
</BaseLayout>