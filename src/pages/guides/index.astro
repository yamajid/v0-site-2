---
import BaseLayout from '@layouts/BaseLayout.astro';
import AuthorByline from '@/components/Astro/AuthorByline.astro';
import { definePageMeta } from '@/lib/metadata';

const meta = definePageMeta({
  title: 'Guides - v0-guide',
  description: 'Step-by-step tutorials and evergreen guides for mastering v0 by Vercel.',
  path: '/guides',
  image: '/assets/advanced-techniques.jpg',
  keywords: ['home', 'affiliate', 'ai-ui'],
});
// const title = 'Guides - v0-guide';
// const description = 'Step-by-step tutorials and evergreen guides for mastering v0 by Vercel.';
---

<BaseLayout meta={meta}>
  <section>
    <h1>Guides</h1>
  </section>

  <article class="mx-auto max-w-4xl px-4 py-12">
    <AuthorByline author="v0 Guide" date={new Date(2026, 3, 20)} linkedIn="https://linkedin.com/in/yamajid" github="https://github.com/yamajid" />
  </article>
</BaseLayout>
