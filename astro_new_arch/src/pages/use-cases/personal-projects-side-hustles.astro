---
// src/pages/use-cases/personal-projects-side-hustles.astro
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'Personal Projects & Side-Hustles with v0';
const description = 'Build landing pages, portfolios, and MVPs without design skills using v0 by Vercel. Real prompts for non-developers and indie makers.';
const useCase = 'personal-projects';
---

<BaseLayout title={title} description={description}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <span class="inline-flex items-center rounded-full bg-primary-100 px-3 py-1 text-sm font-medium text-primary-700">
          Use Case: Side-Hustles
        </span>
        <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-slate-900">{title}</h1>
        <p class="mt-4 text-lg text-slate-600">{description}</p>
      </header>

      <!-- The Problem -->
      <section class="mb-12 p-6 bg-amber-50 border border-amber-200 rounded-xl">
        <h2 class="text-xl font-semibold text-amber-900 mb-3">🎯 The Challenge</h2>
        <p class="text-amber-800">
          Indie makers and side-hustlers often have great ideas but lack design or frontend skills. Hiring a developer is expensive, and no-code tools can feel limiting. You need a fast, affordable way to ship professional-looking projects without technical debt.
        </p>
      </section>

      <!-- How v0 Solves It -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">✅ How v0 Empowers Indie Builders</h2>
        
        <div class="space-y-6">
          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">1. Launch a Landing Page in Minutes</h3>
            <p class="text-slate-600 mb-3">No design skills? Just describe your product:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Prompt:</p>
              <p>"Create a landing page for a productivity app called 'FocusFlow'. Include: hero section with CTA, features grid with icons, testimonials carousel, pricing tiers, and footer. Use a modern, minimalist design with Tailwind CSS."</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: A polished, responsive landing page ready to collect emails or pre-orders.</p>
          </div>

          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">2. Build a Portfolio That Stands Out</h3>
            <p class="text-slate-600 mb-3">Showcase your work without coding a custom site:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Prompt:</p>
              <p>"Design a personal portfolio for a freelance photographer. Include: full-screen hero with name/tagline, project grid with hover effects, about section with bio, contact form, and social links. Use a dark theme with accent colors."</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: A unique, professional portfolio that loads fast and works on all devices.</p>
          </div>

          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">3. Validate Ideas with an MVP</h3>
            <p class="text-slate-600 mb-3">Test demand before over-investing:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Prompt:</p>
              <p>"Create a waitlist signup page for a new AI tool. Include: value proposition headline, benefit bullets, email capture form with validation, and social proof section. Add a confetti animation on successful signup."</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: A conversion-optimized page to validate interest before building the full product.</p>
          </div>
        </div>
      </section>

      <!-- Real Example: Indie SaaS Launch -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">🚀 Real Example: SaaS Waitlist Page</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 bg-green-50 border border-green-200 rounded-lg">
            <h3 class="font-semibold text-green-900 mb-2">Prompt Used</h3>
            <code class="block bg-green-100 p-3 rounded text-sm text-green-800 overflow-x-auto">
              "Build a waitlist page for 'LinkCraft', a tool that auto-generates social media posts from blog URLs. Include: hero with product screenshot mockup, 3 key benefits with icons, email signup form with privacy note, and early-bird discount badge. Use a vibrant, energetic design."
            </code>
          </div>
          <div class="p-5 bg-blue-50 border border-blue-200 rounded-lg">
            <h3 class="font-semibold text-blue-900 mb-2">Result</h3>
            <ul class="space-y-2 text-sm text-blue-800">
              <li>✓ Generated in 38 seconds</li>
              <li>✓ Mobile-optimized layout</li>
              <li>✓ Form validation and success state</li>
              <li>✓ SEO-friendly meta tags ready</li>
              <li>✓ Deployed to Vercel in 2 clicks</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- No-Code Friendly Workflow -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">🔧 Simple Workflow for Non-Developers</h2>
        <ol class="space-y-3 text-slate-700">
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">1.</span>
            <span>Describe your page idea in plain English (no technical jargon needed)</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">2.</span>
            <span>Refine the output with follow-up prompts ("make the button bigger", "add a dark mode toggle")</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">3.</span>
            <span>Export the code or use v0's built-in preview link to share</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">4.</span>
            <span>Connect a form backend (Formspree, Netlify Forms) or deploy to Vercel</span>
          </li>
        </ol>
        <p class="mt-4 text-sm text-slate-500">
          💡 Pro Tip: Use the Free tier to validate your idea, then upgrade to Premium ($20/mo) for unlimited generations and custom domain export when you're ready to launch.
        </p>
      </section>

      <!-- When This Use Case Shines -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">🎯 When to Use v0 for Side-Hustles</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 bg-green-50 border border-green-200 rounded-lg">
            <h3 class="font-semibold text-green-900 mb-2">✅ Ideal For</h3>
            <ul class="space-y-2 text-sm text-green-800">
              <li>• Landing pages for product launches</li>
              <li>• Personal portfolios and resumes</li>
              <li>• Waitlist or pre-order pages</li>
              <li>• Simple web apps with forms</li>
              <li>• Content sites (blogs, guides, resources)</li>
            </ul>
          </div>
          <div class="p-5 bg-amber-50 border border-amber-200 rounded-lg">
            <h3 class="font-semibold text-amber-900 mb-2">⚠️ Consider Alternatives When</h3>
            <ul class="space-y-2 text-sm text-amber-800">
              <li>• You need a full e-commerce store (use Shopify or WooCommerce)</li>
              <li>• Your project requires user accounts/auth (add Clerk or Supabase)</li>
              <li>• You need complex animations (use Framer Motion + custom code)</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to ship your next idea?</h3>
        <p class="text-slate-300 mb-6">Generate professional UIs with v0 — no design or coding skills required.</p>
        <a 
          href="https://v0.dev?ref=v0affiliate"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Start Building Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

      <!-- Related Use Cases -->
      <section class="mt-16 pt-8 border-t border-slate-200">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Explore More Use Cases</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/use-cases/prototyping-wireframing" class="block p-4 rounded-lg border border-slate-200 hover:border-primary-300 hover:bg-primary-50 transition">
            <span class="text-2xl mb-2 block">✏️</span>
            <span class="font-medium text-slate-900">Product Prototyping & Wireframing</span>
          </a>
          <a href="/use-cases/agentic-workflows" class="block p-4 rounded-lg border border-slate-200 hover:border-primary-300 hover:bg-primary-50 transition">
            <span class="text-2xl mb-2 block">🤖</span>
            <span class="font-medium text-slate-900">Agentic Development Workflows</span>
          </a>
        </div>
      </section>

    </article>
  </main>
</BaseLayout>