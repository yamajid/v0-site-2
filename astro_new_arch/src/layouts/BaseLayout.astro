---
// src/layouts/BaseLayout.astro
import Header from '@/components/Astro/Header.astro';
import Footer from '@/components/Astro/Footer.astro';
import SEO from '@/components/Astro/SEO.astro';
import type { PageMetaResolved } from '@/lib/metadata';

interface Props {
  meta: PageMetaResolved;
}

const { meta } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    
    <!-- ✅ Direct prop passing (cleaner than spreading an intermediate object) -->
    <SEO
      title={meta.title}
      description={meta.description}
      image={meta.image}
      canonicalURL={meta.canonicalURL}
      keywords={meta.keywords}
      type={meta.type}
      publishedTime={meta.publishedTime}
    />
  </head>
  <body class="min-h-screen bg-white font-sans text-gray-900 antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @layer base {
    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    body {
      @apply text-gray-900 bg-white;
    }
  }

  @layer components {
    .container {
      @apply mx-auto max-w-7xl px-4 sm:px-6 lg:px-8;
    }
    .btn-primary {
      @apply inline-flex items-center justify-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2;
    }
    .btn-secondary {
      @apply inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2;
    }
  }
</style>