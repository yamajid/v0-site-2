---
import BaseLayout from "./BaseLayout.astro";
import { getPageMeta } from "../data/page-metadata";
import { getSiteUrl } from "@/lib/site-config";
import type { PageMetaResolved } from '@/lib/metadata';

const { pathname } = Astro.url;
const metaData = getPageMeta(pathname);

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  datePublished?: string;
  dateModified?: string;
  faqItems?: { question: string; answer: string }[];
  steps?: { name: string; text: string }[];
  softwareName?: string;
  aggregateRating?: { ratingValue: number; reviewCount: number };
}

const {
  title        = metaData.title,
  description  = metaData.description,
  ogImage      = metaData.ogImage ?? "/assets/og-default.jpg",
  datePublished = metaData.datePublished,
  dateModified  = metaData.dateModified,
  faqItems      = metaData.faqItems,
  steps         = metaData.steps,
  softwareName  = metaData.softwareName,
  aggregateRating = metaData.aggregateRating,
} = Astro.props;

const siteUrl = getSiteUrl();

const resolvedMeta: PageMetaResolved = {
  title: title,
  description: description,
  image: ogImage,
  canonicalURL: siteUrl + pathname,
  type: 'article',
  keywords: [], // Empty array as fallback
  publishedTime: datePublished,
};
---

<BaseLayout 
  meta={resolvedMeta}
  faqItems={faqItems}
  steps={steps}
  softwareName={softwareName}
>
  <slot />
</BaseLayout>
