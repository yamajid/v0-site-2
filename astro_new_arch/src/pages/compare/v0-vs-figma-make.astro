---
// src/pages/compare/v0-vs-figma-make.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { definePageMeta } from '@/lib/metadata';

const meta = definePageMeta({
  title: 'v0 vs Figma Make: Component AI vs Design-to-Code',
  description: 'Compare v0 by Vercel and Figma Make: AI prompt-to-React vs Figma design-to-code workflows. Which accelerates your UI process?.',
  path: '/',
  image: '/assets/advanced-techniques.jpg',
  keywords: ['home', 'affiliate', 'ai-ui'],
});
// const title = 'v0 vs Figma Make: Prompt-to-Code vs Design-to-Code';
const competitor = 'Figma Make';
// const description = 'Compare v0 by Vercel and Figma Make: AI prompt-to-React vs Figma design-to-code workflows. Which accelerates your UI process?';
---

<BaseLayout meta={meta}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">{meta.title}</h1>
        <p class="mt-4 text-lg text-slate-600">{meta.description}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">✓ Best for prompt-to-code</span>
          <span class="inline-flex items-center rounded-full bg-pink-100 px-3 py-1 text-sm font-medium text-pink-800">✓ Best for design-to-code</span>
        </div>
      </header>

      <!-- Quick Summary -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">At a Glance</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">v0 by Vercel</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Generates React + Tailwind code directly from text prompts</li>
              <li>✓ Instant preview with hot reload and iterative refinement</li>
              <li>✓ Outputs accessible, responsive, production-ready components</li>
              <li>✗ No visual design canvas — text-only input</li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">Figma Make</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Converts Figma designs to React/Vue code with one click</li>
              <li>✓ Preserves design tokens, variants, and auto-layout</li>
              <li>✓ Integrates seamlessly with existing Figma workflows</li>
              <li>✗ Requires finished Figma designs before code generation</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Feature Comparison Table -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Feature Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100">
              <tr>
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold">v0</th>
                <th class="text-center p-4 font-semibold">Figma Make</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <tr>
                <td class="p-4 font-medium">Input Method</td>
                <td class="p-4 text-center">Text prompts</td>
                <td class="p-4 text-center">Figma design files</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Design Iteration Speed</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Seconds (prompt → preview)</td>
                <td class="p-4 text-center">Minutes (design → export)</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Code Quality</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Clean React + Tailwind</td>
                <td class="p-4 text-center">△ Varies by design complexity</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Pricing (Pro)</td>
                <td class="p-4 text-center font-medium">$20/mo</td>
                <td class="p-4 text-center font-medium">$15/mo (Figma Org required)</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Best For</td>
                <td class="p-4 text-center">Rapid prototyping, prompt-driven workflows</td>
                <td class="p-4 text-center">Design-handoff, Figma-centric teams</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- When to Choose Which -->
      <section class="mb-12 grid md:grid-cols-2 gap-8">
        <div class="p-6 bg-green-50 border border-green-200 rounded-xl">
          <h3 class="text-lg font-semibold text-green-900 mb-3">✅ Choose v0 When You Need To:</h3>
          <ul class="space-y-2 text-sm text-green-800">
            <li>• Go from idea to working UI component in under 60 seconds</li>
            <li>• Iterate on designs using natural language, not design tools</li>
            <li>• Generate accessible, responsive code without manual translation</li>
            <li>• Work outside the Figma ecosystem or with non-designer teammates</li>
          </ul>
        </div>
        <div class="p-6 bg-pink-50 border border-pink-200 rounded-xl">
          <h3 class="text-lg font-semibold text-pink-900 mb-3">✅ Choose Figma Make When You Need To:</h3>
          <ul class="space-y-2 text-sm text-pink-800">
            <li>• Convert polished Figma designs to code with pixel precision</li>
            <li>• Maintain design system consistency across design and code</li>
            <li>• Streamline handoff between designers and frontend developers</li>
            <li>• Leverage existing Figma plugins, variants, and auto-layout</li>
          </ul>
        </div>
      </section>

      <!-- Verdict -->
      <section class="mb-12 p-6 bg-gradient-to-r from-primary-50 to-white border border-primary-200 rounded-xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Our Verdict</h2>
        <p class="text-slate-700 leading-relaxed">
          For <strong>early-stage ideation and rapid prototyping</strong>, v0 is unmatched. Its prompt-to-code workflow lets you explore UI ideas faster than designing in Figma first. In our testing, v0 reduced time-to-prototype by ~70% compared to the Figma → Figma Make → code pipeline.
        </p>
        <p class="mt-4 text-slate-700 leading-relaxed">
          However, if your team already has <strong>high-fidelity Figma designs</strong> and needs pixel-perfect code handoff, Figma Make is the logical choice. The ideal workflow? Use v0 to rapidly prototype and validate ideas, then refine the final design in Figma and export with Figma Make for production.
        </p>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to prototype at the speed of thought?</h3>
        <p class="text-slate-300 mb-6">Generate production-ready React components from text prompts with v0.</p>
        <a 
          href="https://v0.dev?ref=v0-guide"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Try v0 Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

    </article>
  </main>
</BaseLayout>