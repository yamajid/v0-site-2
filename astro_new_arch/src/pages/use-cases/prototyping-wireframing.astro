---
// src/pages/use-cases/prototyping-wireframing.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import { definePageMeta } from '@/lib/metadata';

const meta = definePageMeta({
  title: 'Product Prototyping & Wireframing with v0',
  description: 'Go from idea to interactive prototype in minutes using v0 by Vercel. Real prompts, iteration workflows, and handoff tips.',
    path: '/',
  image: '/assets/advanced-techniques.jpg',
  keywords: ['home', 'affiliate', 'ai-ui'],
});


// const title = 'Product Prototyping & Wireframing with v0';
// const description = 'Go from idea to interactive prototype in minutes using v0 by Vercel. Real prompts, iteration workflows, and handoff tips.';
const useCase = 'prototyping';
---

<BaseLayout meta={meta}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <span class="inline-flex items-center rounded-full bg-primary-100 px-3 py-1 text-sm font-medium text-primary-700">
          Use Case: Prototyping
        </span>
        <h1 class="mt-4 text-3xl sm:text-4xl font-bold text-slate-900">{meta.title}</h1>
        <p class="mt-4 text-lg text-slate-600">{meta.description}</p>
      </header>

      <!-- The Problem -->
      <section class="mb-12 p-6 bg-amber-50 border border-amber-200 rounded-xl">
        <h2 class="text-xl font-semibold text-amber-900 mb-3">🎯 The Challenge</h2>
        <p class="text-amber-800">
          Traditional wireframing tools (Figma, Sketch) create static mockups that require manual translation to code. This handoff gap causes miscommunication, rework, and delayed launches. Teams need a faster way to validate ideas with interactive, code-ready prototypes.
        </p>
      </section>

      <!-- How v0 Solves It -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">✅ How v0 Transforms Prototyping</h2>
        
        <div class="space-y-6">
          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">1. Describe → Generate → Iterate</h3>
            <p class="text-slate-600 mb-3">Skip the design tool entirely. Prompt v0 with your concept:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Prompt:</p>
              <p>"Create a mobile-first onboarding flow for a fitness app: 1) Welcome screen with CTA, 2) Goal selection cards, 3) Permission requests, 4) Success confirmation. Use smooth transitions and a vibrant color scheme."</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: Interactive React prototype you can click through immediately.</p>
          </div>

          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">2. Refine with Natural Language</h3>
            <p class="text-slate-600 mb-3">No need to redraw frames. Just describe changes:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Follow-up prompts:</p>
              <p>"Make the primary button use a gradient from purple to pink"</p>
              <p>"Add a skip button to the permission screen"</p>
              <p>"Animate the goal cards to slide in from the bottom"</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: Instant visual updates without context-switching tools.</p>
          </div>

          <div class="p-5 bg-slate-50 rounded-lg border border-slate-200">
            <h3 class="font-semibold text-slate-900 mb-2">3. Export Code-Ready Components</h3>
            <p class="text-slate-600 mb-3">When the prototype is validated, export production code:</p>
            <div class="bg-slate-900 text-slate-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
              <p class="text-green-400"># Export options:</p>
              <p>• Copy React + Tailwind code directly</p>
              <p>• Sync to GitHub (Premium)</p>
              <p>• Deploy preview to Vercel (with project setup)</p>
            </div>
            <p class="mt-3 text-sm text-slate-500">✅ Result: Zero handoff friction — the prototype <em>is</em> the implementation.</p>
          </div>
        </div>
      </section>

      <!-- Real Example: E-commerce Checkout -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">🛒 Real Example: Checkout Flow Prototype</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 bg-green-50 border border-green-200 rounded-lg">
            <h3 class="font-semibold text-green-900 mb-2">Prompt Used</h3>
            <code class="block bg-green-100 p-3 rounded text-sm text-green-800 overflow-x-auto">
              "Design a 3-step checkout flow for an e-commerce site: 1) Cart summary with edit/remove, 2) Shipping address form with auto-complete, 3) Payment method selection (card, PayPal, Apple Pay). Include progress indicator and mobile-responsive layout."
            </code>
          </div>
          <div class="p-5 bg-blue-50 border border-blue-200 rounded-lg">
            <h3 class="font-semibold text-blue-900 mb-2">Result</h3>
            <ul class="space-y-2 text-sm text-blue-800">
              <li>✓ Generated in 62 seconds</li>
              <li>✓ Fully interactive prototype (clickable steps)</li>
              <li>✓ Form validation logic included</li>
              <li>✓ Accessible labels and ARIA attributes</li>
              <li>✓ Clean code ready for backend integration</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Pro Tips for Prototyping -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">💡 Pro Tips for Faster Prototyping</h2>
        <ul class="space-y-3 text-slate-700">
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">•</span>
            <span><strong>Start broad, then refine</strong>: Prompt for the full flow first, then iterate on specific screens.</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">•</span>
            <span><strong>Use constraint prompts</strong>: "Use Tailwind CSS", "Mobile-first", "WCAG AA compliant" to guide output quality.</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">•</span>
            <span><strong>Save iterations</strong>: Use v0's version history to compare design directions before committing.</span>
          </li>
          <li class="flex gap-3">
            <span class="font-bold text-primary-600">•</span>
            <span><strong>Test with users early</strong>: Share the interactive preview link for rapid feedback before coding.</span>
          </li>
        </ul>
      </section>

      <!-- When This Use Case Shines -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">🎯 When to Use v0 for Prototyping</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-5 bg-green-50 border border-green-200 rounded-lg">
            <h3 class="font-semibold text-green-900 mb-2">✅ Ideal For</h3>
            <ul class="space-y-2 text-sm text-green-800">
              <li>• MVP validation with stakeholders</li>
              <li>• User testing interactive flows</li>
              <li>• Pitch decks with live demos</li>
              <li>• Design system exploration</li>
              <li>• Rapid A/B test concepting</li>
            </ul>
          </div>
          <div class="p-5 bg-amber-50 border border-amber-200 rounded-lg">
            <h3 class="font-semibold text-amber-900 mb-2">⚠️ Consider Alternatives When</h3>
            <ul class="space-y-2 text-sm text-amber-800">
              <li>• You need pixel-perfect brand compliance (use Figma first)</li>
              <li>• Your prototype requires complex animations (use Framer)</li>
              <li>• You're documenting design specs for handoff (use Figma + Dev Mode)</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to prototype at the speed of thought?</h3>
        <p class="text-slate-300 mb-6">Generate interactive, code-ready prototypes with v0 — free to start.</p>
        <a 
          href="https://v0.dev?ref=v0-guide"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Start Prototyping Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

      <!-- Related Use Cases -->
      <section class="mt-16 pt-8 border-t border-slate-200">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Explore More Use Cases</h3>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/use-cases/internal-tools-dashboards" class="block p-4 rounded-lg border border-slate-200 hover:border-primary-300 hover:bg-primary-50 transition">
            <span class="text-2xl mb-2 block">📊</span>
            <span class="font-medium text-slate-900">Internal Tools & Dashboards</span>
          </a>
          <a href="/use-cases/agentic-workflows" class="block p-4 rounded-lg border border-slate-200 hover:border-primary-300 hover:bg-primary-50 transition">
            <span class="text-2xl mb-2 block">🤖</span>
            <span class="font-medium text-slate-900">Agentic Development Workflows</span>
          </a>
        </div>
      </section>

    </article>
  </main>
</BaseLayout>