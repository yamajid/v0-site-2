---
// src/pages/compare/v0-vs-github-copilot.astro
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'v0 vs GitHub Copilot: UI AI vs General Code Assistant';
const competitor = 'GitHub Copilot';
const description = 'Compare v0 by Vercel and GitHub Copilot: specialized UI generation vs general-purpose AI coding assistant. Features, pricing, and workflow fit.';
---

<BaseLayout title={title} description={description}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">{title}</h1>
        <p class="mt-4 text-lg text-slate-600">{description}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">✓ Best for UI components</span>
          <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800">✓ Best for general coding</span>
        </div>
      </header>

      <!-- Quick Summary -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">At a Glance</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">v0 by Vercel</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Specialized AI for generating React + Tailwind UI components</li>
              <li>✓ Instant visual preview with hot reload and iterative editing</li>
              <li>✓ Outputs accessible, responsive, production-ready code</li>
              <li>✗ Focused only on frontend UI — no backend or general coding</li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">GitHub Copilot</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ General-purpose AI assistant for any programming language</li>
              <li>✓ Context-aware code completion inside your IDE (VS Code, JetBrains)</li>
              <li>✓ Helps with backend logic, tests, docs, and debugging</li>
              <li>✗ UI generation less specialized; requires more manual prompting</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Feature Comparison Table -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Feature Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100">
              <tr>
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold">v0</th>
                <th class="text-center p-4 font-semibold">GitHub Copilot</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <tr>
                <td class="p-4 font-medium">Primary Focus</td>
                <td class="p-4 text-center">UI component generation</td>
                <td class="p-4 text-center">General code assistance</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">UI Output Quality</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Excellent (specialized)</td>
                <td class="p-4 text-center text-amber-600">△ Good (generalist)</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">IDE Integration</td>
                <td class="p-4 text-center">Web app (copy/paste code)</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Native in VS Code, JetBrains</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Pricing</td>
                <td class="p-4 text-center font-medium">$20/mo (Premium)</td>
                <td class="p-4 text-center font-medium">$10/mo (Individual)</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Best For</td>
                <td class="p-4 text-center">Frontend devs, designers, rapid UI prototyping</td>
                <td class="p-4 text-center">Full-stack devs, backend work, general coding tasks</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- When to Choose Which -->
      <section class="mb-12 grid md:grid-cols-2 gap-8">
        <div class="p-6 bg-green-50 border border-green-200 rounded-xl">
          <h3 class="text-lg font-semibold text-green-900 mb-3">✅ Choose v0 When You Need To:</h3>
          <ul class="space-y-2 text-sm text-green-800">
            <li>• Generate complex, accessible React + Tailwind components from text</li>
            <li>• Iterate on UI designs visually with instant preview and hot reload</li>
            <li>• Export clean, production-ready code without manual cleanup</li>
            <li>• Focus purely on frontend quality without context-switching</li>
          </ul>
        </div>
        <div class="p-6 bg-gray-50 border border-gray-200 rounded-xl">
          <h3 class="text-lg font-semibold text-gray-900 mb-3">✅ Choose GitHub Copilot When You Need To:</h3>
          <ul class="space-y-2 text-sm text-gray-800">
            <li>• Get AI assistance across your entire codebase (frontend + backend)</li>
            <li>• Write tests, documentation, and boilerplate code faster</li>
            <li>• Work inside your existing IDE without switching contexts</li>
            <li>• Get help with debugging, refactoring, and learning new frameworks</li>
          </ul>
        </div>
      </section>

      <!-- Verdict -->
      <section class="mb-12 p-6 bg-gradient-to-r from-primary-50 to-white border border-primary-200 rounded-xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Our Verdict</h2>
        <p class="text-slate-700 leading-relaxed">
          For <strong>UI component generation</strong>, v0 is significantly more effective. Its specialized training on React + Tailwind patterns produces components with better accessibility, responsiveness, and code structure than general-purpose assistants. In our testing, v0 reduced UI prototyping time by ~60% compared to prompting Copilot for the same components.
        </p>
        <p class="mt-4 text-slate-700 leading-relaxed">
          However, GitHub Copilot remains invaluable for <strong>general coding tasks</strong> — backend logic, tests, documentation, and debugging. The ideal setup? Use <strong>v0 for UI prototyping</strong>, then switch to Copilot in your IDE for implementation, refinement, and full-stack development. They complement each other beautifully.
        </p>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to supercharge your UI workflow?</h3>
        <p class="text-slate-300 mb-6">Generate production-ready React components with v0 — free to start.</p>
        <a 
          href="https://v0.dev?ref=v0affiliate"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Try v0 Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

    </article>
  </main>
</BaseLayout>