---
// src/pages/compare/v0-vs-bolt.astro
import BaseLayout from '@layouts/BaseLayout.astro';

const title = 'v0 vs Bolt.new: Component AI vs Full-App AI Builder';
const competitor = 'Bolt.new';
const description = 'Compare v0 by Vercel and Bolt.new: specialized UI component generation vs end-to-end app creation. Features, pricing, and workflow fit.';
---

<BaseLayout title={title} description={description}>
  <main class="container mx-auto px-4 py-12">
    <article class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-slate-900">{title}</h1>
        <p class="mt-4 text-lg text-slate-600">{description}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">✓ Best for UI components</span>
          <span class="inline-flex items-center rounded-full bg-purple-100 px-3 py-1 text-sm font-medium text-purple-800">✓ Best for full apps</span>
        </div>
      </header>

      <!-- Quick Summary -->
      <section class="mb-12 p-6 bg-slate-50 rounded-xl border border-slate-200">
        <h2 class="text-xl font-semibold text-slate-900 mb-4">At a Glance</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">v0 by Vercel</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Generates React + Tailwind components from text prompts</li>
              <li>✓ Instant preview with hot reload and edit-in-place</li>
              <li>✓ Exports clean, accessible, production-ready code</li>
              <li>✗ Focused on frontend UI components only</li>
            </ul>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-2">Bolt.new</h3>
            <ul class="space-y-2 text-sm text-slate-600">
              <li>✓ Generates full-stack applications from a single prompt</li>
              <li>✓ Includes backend logic, database schema, and auth</li>
              <li>✓ One-click deploy with built-in hosting</li>
              <li>✗ UI output less polished than specialized tools</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Feature Comparison Table -->
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">Feature Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-slate-200 rounded-lg overflow-hidden">
            <thead class="bg-slate-100">
              <tr>
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold">v0</th>
                <th class="text-center p-4 font-semibold">Bolt.new</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              <tr>
                <td class="p-4 font-medium">UI Component Quality</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Excellent</td>
                <td class="p-4 text-center text-amber-600">△ Good</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Full-App Generation</td>
                <td class="p-4 text-center text-amber-600">✗ No</td>
                <td class="p-4 text-center text-green-600 font-semibold">✓ Yes</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Free Tier</td>
                <td class="p-4 text-center">100 generations/month</td>
                <td class="p-4 text-center">Limited daily credits</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Pricing (Pro)</td>
                <td class="p-4 text-center font-medium">$20/mo</td>
                <td class="p-4 text-center font-medium">$20/mo</td>
              </tr>
              <tr>
                <td class="p-4 font-medium">Code Export</td>
                <td class="p-4 text-center">Clean React + Tailwind, ready to copy</td>
                <td class="p-4 text-center">Full project download or Git push</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="p-4 font-medium">Best For</td>
                <td class="p-4 text-center">Designers, frontend devs, rapid UI iteration</td>
                <td class="p-4 text-center">Indie hackers, MVP builders, full-stack prototypes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- When to Choose Which -->
      <section class="mb-12 grid md:grid-cols-2 gap-8">
        <div class="p-6 bg-green-50 border border-green-200 rounded-xl">
          <h3 class="text-lg font-semibold text-green-900 mb-3">✅ Choose v0 When You Need To:</h3>
          <ul class="space-y-2 text-sm text-green-800">
            <li>• Generate pixel-perfect, accessible React components with Tailwind CSS</li>
            <li>• Iterate on UI design ideas rapidly without context-switching</li>
            <li>• Export clean code to integrate into your existing Vercel/Next.js project</li>
            <li>• Focus purely on frontend quality without backend complexity</li>
          </ul>
        </div>
        <div class="p-6 bg-purple-50 border border-purple-200 rounded-xl">
          <h3 class="text-lg font-semibold text-purple-900 mb-3">✅ Choose Bolt.new When You Need To:</h3>
          <ul class="space-y-2 text-sm text-purple-800">
            <li>• Build a complete MVP from idea to deployed app in one session</li>
            <li>• Generate backend logic, database models, and auth flows automatically</li>
            <li>• Avoid managing separate frontend/backend tooling</li>
            <li>• Prioritize speed-to-market over UI polish</li>
          </ul>
        </div>
      </section>

      <!-- Verdict -->
      <section class="mb-12 p-6 bg-gradient-to-r from-primary-50 to-white border border-primary-200 rounded-xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Our Verdict</h2>
        <p class="text-slate-700 leading-relaxed">
          For <strong>UI component generation</strong>, v0 is significantly stronger. In side-by-side testing, v0 produced components with better accessibility compliance (WCAG 2.1 AA), more consistent Tailwind class usage, and cleaner prop typing. Bolt.new excels at breadth — generating entire apps — but its UI output often requires manual refinement for production use.
        </p>
        <p class="mt-4 text-slate-700 leading-relaxed">
          The ideal workflow? Use <strong>v0 to generate your frontend components</strong>, then import them into a Bolt.new project (or your preferred stack) for full-app assembly. This hybrid approach gives you v0's UI quality with Bolt's deployment convenience.
        </p>
      </section>

      <!-- Affiliate CTA -->
      <section class="text-center p-8 bg-slate-900 text-white rounded-2xl">
        <h3 class="text-xl font-semibold mb-3">Ready to build better UIs faster?</h3>
        <p class="text-slate-300 mb-6">Start generating production-ready React components with v0 today.</p>
        <a 
          href="https://v0.dev?ref=v0affiliate"
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-slate-900 font-bold rounded-lg hover:bg-slate-100 transition transform hover:scale-105"
        >
          Try v0 Free →
        </a>
        <p class="mt-4 text-xs text-slate-400">Affiliate link: We may earn a commission at no extra cost to you.</p>
      </section>

    </article>
  </main>
</BaseLayout>