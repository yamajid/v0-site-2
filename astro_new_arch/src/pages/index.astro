---
import BaseLayout from '@layouts/BaseLayout.astro';
import AffiliateInteractiveCalculator from '@components/React/AffiliateInteractiveCalculator.tsx';
import FeatureTabs from '@components/React/FeatureTabs.tsx';
import { definePageMeta } from '@lib/metadata.ts';

const meta = definePageMeta({
  title: 'Home',
  description: 'Discover how v0 by Vercel revolutionizes UI development with AI. Get exclusive insights, comparisons, and affiliate deals.',
  path: '/',
  image: '/assets/og-home.jpg',
  keywords: ['home', 'affiliate', 'ai-ui'],
});
---

<BaseLayout meta={meta}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-20 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700">
          🚀 Official v0-guide Partner
        </span>
        <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          Build UIs Faster with{' '}
          <span class="bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent">
            v0 by Vercel
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
          {description}
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://v0.dev?ref=v0-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-primary-600 px-8 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-primary-700"
          >
            Get Started Free →
          </a>
          <a
            href="/compare"
            class="rounded-lg border border-gray-300 bg-white px-8 py-3 text-base font-semibold text-gray-900 shadow-sm transition-colors hover:bg-gray-50"
          >
            See Comparisons
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative Background -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[1000px] w-[1000px] -translate-x-1/2 bg-gradient-to-br from-primary-100/50 to-accent-100/50 blur-3xl" />
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Why Choose v0?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          The most advanced AI-powered UI generation platform built by Vercel.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Feature 1 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Lightning Fast</h3>
          <p class="mt-2 text-gray-600">
            Generate production-ready React components in seconds using natural language prompts.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Clean Code Output</h3>
          <p class="mt-2 text-gray-600">
            Get TypeScript, Tailwind CSS, and React code that follows best practices.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Responsive Designs</h3>
          <p class="mt-2 text-gray-600">
            All generated components are mobile-first and fully responsive by default.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Customizable</h3>
          <p class="mt-2 text-gray-600">
            Iterate on designs with follow-up prompts to get exactly what you need.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Team Collaboration</h3>
          <p class="mt-2 text-gray-600">
            Share components and collaborate with your team in real-time.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Enterprise Security</h3>
          <p class="mt-2 text-gray-600">
            SOC 2 compliant with enterprise-grade security and privacy features.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Calculator Section -->
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <AffiliateInteractiveCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- Feature Comparison Section -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          How Does v0 Compare?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          See why developers and teams are choosing v0 over the competition.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl">
        <FeatureTabs competitor="Other AI Tools" client:visible />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-primary-600 to-accent-600 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Ready to Transform Your UI Workflow?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        Join thousands of developers who are already building faster with v0.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://v0.dev?ref=v0-guide"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg bg-white px-8 py-3 text-base font-semibold text-primary-600 shadow-sm transition-colors hover:bg-gray-100"
        >
          Start Building for Free →
        </a>
        <a
          href="/blog"
          class="rounded-lg border border-white bg-transparent px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          Read Our Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
