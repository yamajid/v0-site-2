---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorByline from '@/components/Astro/AuthorByline.astro';
import AffiliateInteractiveCalculator from '@/components/React/AffiliateInteractiveCalculator.tsx';
import FeatureTabs from '@/components/React/FeatureTabs.tsx';
import { definePageMeta } from '@/lib/metadata.ts';
import { getPageMeta } from '@/data/page-metadata.ts';

const meta = definePageMeta({
  title: 'v0 — Prompt to Production — Agentic AI for React — AI UI Generator',
  description: 'v0 scaffolds entire features from prompts. Iterate with natural language. Ship production-ready React with Next.js App Router and shadcn/ui in minutes.',
  path: '/',
  image: '/assets/og-home.jpg',
  keywords: ['agentic ai', 'prompt to production', 'react ui generation', 'vibe coding', 'next.js', 'v0', 'shadcn/ui', 'server components', 'typescript', 'tailwindcss'],
});

// Extract FAQ items from page metadata for schema generation
const pageMeta = getPageMeta('/');
const faqItems = pageMeta.faqItems || [];

// Define HowTo steps for workflow schema
const steps = [
  {
    name: 'Write Your Prompt',
    text: 'Describe what you need in plain English. "Create a sales dashboard with revenue card, customer table, and trend chart."',
  },
  {
    name: 'Get Full Scaffolding',
    text: 'v0 generates entire component trees with Next.js, shadcn/ui, Server Components, and Tailwind. No snippets—full features.',
  },
  {
    name: 'Refine with Natural Language',
    text: 'Iterate instantly. "Add dark mode." "Reorganize columns." v0 understands context and adapts intelligently.',
  },
  {
    name: 'Deploy to Production',
    text: 'Push to GitHub with one click. Deploy to Vercel instantly. Your entire workflow, no copy-paste friction.',
  },
];
---

<BaseLayout meta={meta} faqItems={faqItems} steps={steps}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-b from-primary-50 to-white py-20 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="inline-block rounded-full bg-primary-100 px-4 py-1.5 text-sm font-medium text-primary-700">
          ✨v0 Agentic AI for React Developers
        </span>
        <h1 class="mt-6 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
           Prompt to Production
          <span class="block bg-gradient-to-r from-primary-600 to-accent-600 bg-clip-text text-transparent">
            in Minutes
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-600">
          v0 scaffolds entire features from prompts. You iterate with natural language. Ship production-ready React with Next.js, shadcn/ui, and Server Components.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://v0.dev?ref=v0-guide"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-primary-600 px-8 py-3 text-base font-semibold text-white shadow-sm transition-colors hover:bg-primary-700"
          >
            Start Vibe Coding →
          </a>
          <a
            href="/compare"
            class="rounded-lg border border-gray-300 bg-white px-8 py-3 text-base font-semibold text-gray-900 shadow-sm transition-colors hover:bg-gray-50"
          >
            See Comparisons
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative Background -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[1000px] w-[1000px] -translate-x-1/2 bg-gradient-to-br from-primary-100/50 to-accent-100/50 blur-3xl" />
    </div>
  </section>

  <!-- Features Section (4 Core Agentic Capabilities) -->
  <section id="features" class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Built for Agentic Development
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          v0 isn't reactive. It understands intent, scaffolds features, and iterates intelligently.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2">
        <!-- Feature 1: Context-Aware Generation -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Check mark icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7 12a5 5 0 1110 0A5 5 0 017 12z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Context-Aware Scaffolding</h3>
          <p class="mt-2 text-gray-600">
            Entire feature trees from one prompt. Not snippets—full components with context preserved across iterations.
          </p>
        </div>

        <!-- Feature 2: Live Iteration -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Refresh icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Vibe Coding Loop</h3>
          <p class="mt-2 text-gray-600">
            Natural language refinement. "Add dark mode." "Reorganize columns." v0 understands and adapts.
          </p>
        </div>

        <!-- Feature 3: Stack Intelligence -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Lightning icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">Modern Stack Default</h3>
          <p class="mt-2 text-gray-600">
            Next.js App Router, shadcn/ui, Server Components, TypeScript, Tailwind. <a href="/guides" class="font-medium text-primary-600 hover:underline">Learn the stack →</a>
          </p>
        </div>

        <!-- Feature 4: GitHub-Native Workflow -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
            <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-label="Code branches icon">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-gray-900">GitHub-Native Sync</h3>
          <p class="mt-2 text-gray-600">
            Push to branches. Deploy to Vercel. One-click. Your entire workflow, no copy-paste.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Your Agentic Workflow
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          From prompt to production. Four simple steps powered by intent-aware AI.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((step, index) => (
          <div class="text-center">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary-100">
              <span class="text-2xl font-bold text-primary-600">{index + 1}</span>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-gray-900">{step.name}</h3>
            <p class="mt-2 text-sm text-gray-600">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Interactive Calculator Section -->
  <section class="bg-gray-50 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <AffiliateInteractiveCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- Feature Comparison Section -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          How Does v0 Compare?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
          <a href="/compare" class="font-medium text-primary-600 hover:underline">See detailed comparisons</a> why developers are choosing agentic AI over reactive tools.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl">
        <FeatureTabs competitor="Other AI Tools" client:visible />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-gradient-to-r from-primary-600 to-accent-600 py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Ship Features, Not Files
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-primary-100">
        Start agentic development today. From prompt to production in minutes.
      </p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://v0.dev?ref=v0-guide"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg bg-white px-8 py-3 text-base font-semibold text-primary-600 shadow-sm transition-colors hover:bg-gray-100"
        >
          Launch Your First Project →
        </a>
        <a
          href="/blog"
          class="rounded-lg border border-white bg-transparent px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          Read the Docs
        </a>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-4xl px-4 py-12">
    <AuthorByline author="v0 Guide" date={new Date(2026, 3, 20)} linkedIn="https://linkedin.com/in/yamajid" github="https://github.com/yamajid" />
  </article>
</BaseLayout>
