---
// src/pages/pricing.astro
// Updated: 2026 positioning (token-based billing, model tiers, current brand URL)

import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthorByline from '@/components/Astro/AuthorByline.astro';
import { definePageMeta } from '@/lib/metadata';

const title = 'v0 Pricing (2026) - v0-guide';
const description = 'Understand v0 pricing in 2026: free access, token-based paid usage, model tiers (Mini/Pro/Max), and team options.';

const meta = definePageMeta({
  title: 'v0 Pricing (2026) - v0-guide',
  description: 'Understand v0 pricing in 2026: free access, token-based paid usage, model tiers (Mini/Pro/Max), and team options.',
  path: '/pricing',
  image: '/assets/og-home.jpg',
  keywords: ['v0 pricing 2026', 'v0 token billing', 'v0 mini pro max', 'v0 app'],
});
// 2026-safe plan framing: avoid hardcoding volatile pricing numbers
const tiers = [
  {
    name: 'Free',
    price: '$0',
    frequency: '/mo',
    description: 'Good for first projects and testing v0 prompts before committing to paid usage.',
    features: [
      'Starter usage allocation',
      'Core UI generation features',
      'Basic export workflow',
      'Great for initial experimentation'
    ],
    cta: 'Start for Free',
    url: 'https://v0.app?ref=v0-guide',
    popular: false
  },
  {
    name: 'Paid Usage',
    price: 'Varies',
    frequency: '/mo',
    description: 'Token-based usage for creators shipping production features more frequently.',
    features: [
      'Token-based billing',
      'Higher generation capacity',
      'Priority workflow features',
      'Private project support',
      'Access to advanced models'
    ],
    cta: 'View Paid Options',
    url: 'https://v0.app/pricing?ref=v0-guide',
    popular: true
  },
  {
    name: 'Team',
    price: 'Varies',
    frequency: '/seat',
    description: 'Collaboration-focused setup for teams that iterate across product and engineering.',
    features: [
      'Everything in paid usage',
      'Shared team workspace',
      'Version history',
      'Collaborative workflows',
      'Admin dashboard'
    ],
    cta: 'Start Team Trial',
    url: 'https://v0.app/pricing?ref=v0-guide',
    popular: false
  },
  {
    name: 'Business',
    price: 'Custom',
    frequency: '/team',
    description: 'Security and governance capabilities for larger product organizations.',
    features: [
      'Everything in Team',
      'SSO (Single Sign-On)',
      'Audit logs',
      'Dedicated support',
      'SLA guarantees'
    ],
    cta: 'Contact Sales',
    url: 'https://v0.app/pricing?ref=v0-guide',
    popular: false
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    frequency: '',
    description: 'Tailored solutions for large organizations with specific needs.',
    features: [
      'Everything in Business',
      'On-premise deployment',
      'Custom model fine-tuning',
      'White-label options',
      'Dedicated account manager'
    ],
    cta: 'Contact Sales',
    url: 'https://v0.app/pricing?ref=v0-guide',
    popular: false
  }
];

const softwareOffers = [
  { price: 0, currency: 'USD', availability: 'https://schema.org/InStock' },
  { price: 20, currency: 'USD', availability: 'https://schema.org/InStock' }
];
---

<BaseLayout 
  meta={meta}
  softwareName="v0 by Vercel"
  softwareCategory="DeveloperApplication"
  softwareOffers={softwareOffers}
>
  
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-50 to-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
        Simple, Transparent Pricing
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm text-slate-500">
        Last reviewed April 2026. v0 now uses token-based billing and model tiers, so always confirm current limits on the official pricing page.
      </p>
    </div>
  </section>

  <!-- Pricing Grid -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Note: For Enterprise/Custom, we might stack differently, but grid works for all 5 -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        
        {tiers.map((tier) => (
          <div class={`relative flex flex-col rounded-2xl border p-6 shadow-sm transition-all hover:shadow-md ${tier.popular ? 'border-primary-500 ring-2 ring-primary-500 ring-offset-2' : 'border-slate-200'}`}>
            
            <!-- Popular Badge -->
            {tier.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
                Most Popular
              </span>
            )}

            <!-- Header -->
            <div class="mb-4">
              <h3 class="text-lg font-semibold text-slate-900">{tier.name}</h3>
              <p class="mt-1 text-sm text-slate-500">{tier.description}</p>
            </div>

            <!-- Price -->
            <div class="mb-6">
              <span class="text-4xl font-bold text-slate-900">{tier.price}</span>
              <span class="text-slate-500">{tier.frequency}</span>
            </div>

            <!-- Features -->
            <ul class="mb-8 flex-1 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <svg class="h-5 w-5 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a 
              href={tier.url}
              class={`block w-full rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${
                tier.popular 
                  ? 'bg-primary-600 text-white hover:bg-primary-700 shadow-sm' 
                  : 'bg-slate-900 text-white hover:bg-slate-800'
              }`}
              target="_blank"
              rel="noopener noreferrer"
            >
              {tier.cta}
            </a>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- FAQ Section (SEO Boost) -->
  <section class="bg-slate-50 py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center text-slate-900 mb-10">Frequently Asked Questions</h2>
      
      <div class="space-y-8">
        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>How does token-based billing work in v0?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            v0 usage is metered by tokens, which typically vary based on prompt complexity, chosen model tier, and output length. If your plan limit is reached, you can usually wait for reset windows or move to a higher-capacity paid option.
          </p>
        </details>

        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>What is the difference between Mini, Pro, and Max models?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            Model tiers generally trade speed and cost against output depth. Mini is typically suited to simpler iterations, Pro balances quality and efficiency for everyday work, and Max is better for complex generation tasks where output quality matters most.
          </p>
        </details>

        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>Can v0 support full-stack workflows and GitHub export?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            Yes, current v0 workflows include Git-connected iteration and runtime-oriented testing patterns for broader app delivery. For production systems, you should still validate backend security, data modeling, and deployment architecture in your own environment.
          </p>
        </details>

        <details class="group rounded-xl bg-white p-6 shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between font-medium text-slate-900">
            <span>Should I trust static pricing screenshots from old guides?</span>
            <span class="ml-4 transition-transform group-open:rotate-180">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </span>
          </summary>
          <p class="mt-4 text-slate-600 group-open:animate-fadeIn">
            No. Pricing and model access can change quickly, and many older pages still reference pre-2026 credit systems or old branding. Use this page for context, then verify final numbers directly on the official v0 pricing page before making plan decisions.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to build faster?</h2>
      <p class="mt-4 text-lg text-slate-300">
        Join thousands of developers using v0 to accelerate their UI workflow.
      </p>
      <div class="mt-8">
        <a 
          href="https://v0.app?ref=v0-guide"
          class="inline-flex items-center justify-center rounded-lg bg-primary-600 px-8 py-3 text-base font-bold text-white shadow-lg transition-transform hover:scale-105 hover:bg-primary-700"
        >
          Start Building for Free
        </a>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-4xl px-4 py-12">
    <AuthorByline author="v0 Guide" date={new Date(2026, 3, 20)} linkedIn="https://linkedin.com/in/yamajid" github="https://github.com/yamajid" />
  </article>
</BaseLayout>